{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "strict": true,
    "skipLibCheck": true,

    "outDir": "dist",
    "rootDir": "./",

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "noEmit": false
  },
  "include": ["src", "api"]
}